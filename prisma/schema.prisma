generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model CompanyInfo {
  id                Int      @id @default(1)
  companyName       String   @db.VarChar(100)
  representative    String   @db.VarChar(50)
  address           String   @db.VarChar(200)
  phone             String   @db.VarChar(30)
  fax               String?  @db.VarChar(30)
  businessNumber    String   @db.VarChar(20)
  businessType      String?  @db.VarChar(50)
  businessItem      String?  @db.VarChar(50)
  logoUrl           String?  @db.VarChar(500)
  sealUrl           String?  @db.VarChar(500)
  passwordHash      String?  @db.VarChar(200)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("company_info")
}

model BankAccount {
  id                Int      @id @default(autoincrement())
  bankName          String   @db.VarChar(30)
  accountNumber     String   @db.VarChar(50)
  accountHolder     String   @db.VarChar(50)
  memo              String?  @db.VarChar(200)
  isDefault         Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions      Transaction[]

  @@map("bank_accounts")
}

model SystemOption {
  id                Int      @id @default(autoincrement())
  category          String   @db.VarChar(50)
  label             String   @db.VarChar(100)
  value             String   @db.VarChar(100)
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([category, value])
  @@index([category, isActive])
  @@map("system_options")
}

model Material {
  id                Int      @id @default(autoincrement())
  paperType         String?  @db.VarChar(50)
  backing           String?  @db.VarChar(50)
  adhesive          String?  @db.VarChar(50)
  thickness         String?  @db.VarChar(20)
  manufacturer      String?  @db.VarChar(100)
  code              String?  @db.VarChar(150)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([paperType])
  @@index([code])
  @@map("materials")
}

model Client {
  id                Int      @id @default(autoincrement())
  companyName       String   @db.VarChar(100)
  clientType        String   @default("매출") @db.VarChar(10)
  representative    String?  @db.VarChar(50)
  contactName       String?  @db.VarChar(50)
  phone             String?  @db.VarChar(30)
  fax               String?  @db.VarChar(30)
  email             String?  @db.VarChar(100)
  address           String?  @db.VarChar(200)
  businessNumber    String?  @db.VarChar(20)
  businessType      String?  @db.VarChar(50)
  businessItem      String?  @db.VarChar(50)
  memo              String?  @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders            Order[]
  estimates         Estimate[]
  transactions      Transaction[]
  salesRecords      SalesRecord[]

  @@index([companyName])
  @@index([contactName])
  @@index([clientType])
  @@map("clients")
}

model Product {
  id                Int      @id @default(autoincrement())
  productCode       String?  @unique @db.VarChar(10)
  productName       String   @db.VarChar(200)
  spec              String?  @db.VarChar(100)
  printType         String?  @db.VarChar(50)
  material          String?  @db.VarChar(50)
  unitPrice         Decimal? @db.Decimal(12, 0)
  memo              String?  @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderItems        OrderItem[]
  estimateItems     EstimateItem[]
  transactionItems  TransactionItem[]

  @@index([productName])
  @@index([spec])
  @@map("products")
}

model Order {
  id                Int      @id @default(autoincrement())
  orderNumber       String   @unique @db.VarChar(30)
  clientId          Int
  orderDate         DateTime @db.Date
  dueDate           DateTime? @db.Date
  orderer           String?  @db.VarChar(50)
  worker            String?  @db.VarChar(50)
  clientContact     String?  @db.VarChar(50)
  clientPhone       String?  @db.VarChar(30)
  deliveryMethod    String?  @db.VarChar(20)
  deliveryRegion    String?  @db.VarChar(50)
  photoInspection   Boolean  @default(false)
  sampleShipping    Boolean  @default(false)
  tightRoll         Boolean  @default(false)
  packagingType     String?  @db.VarChar(20)
  deliveryType      String?  @db.VarChar(20)
  courierType       String?  @db.VarChar(20)
  deliveryAddress   String?  @db.VarChar(200)
  receiverName      String?  @db.VarChar(50)
  receiverPhone     String?  @db.VarChar(30)
  note              String?  @db.Text
  status            String   @default("DRAFT") @db.VarChar(20)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client            Client   @relation(fields: [clientId], references: [id])
  items             OrderItem[]

  @@index([clientId])
  @@index([orderDate])
  @@index([dueDate])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                Int      @id @default(autoincrement())
  orderId           Int
  productId         Int?
  productName       String   @db.VarChar(200)
  printType         String?  @db.VarChar(50)
  printPrice        Decimal? @db.Decimal(12, 0)
  sheets            Int?
  sheetsPerRoll     Int?
  unitPrice         Decimal? @db.Decimal(12, 0)
  supplyAmount      Decimal? @db.Decimal(12, 0)
  material          String?  @db.VarChar(50)
  materialWidth     Decimal? @db.Decimal(6, 1)
  paperType         String?  @db.VarChar(50)
  backing           String?  @db.VarChar(50)
  adhesive          String?  @db.VarChar(50)
  thickness         String?  @db.VarChar(20)
  manufacturer      String?  @db.VarChar(100)
  perforation       Boolean  @default(false)
  sizeWidth         Decimal? @db.Decimal(6, 1)
  sizeHeight        Decimal? @db.Decimal(6, 1)
  shape             String?  @db.VarChar(20)
  okkuri            Decimal? @db.Decimal(6, 1)
  lamination        String?  @db.VarChar(20)
  foil              String?  @db.VarChar(20)
  cuttingMethod     String?  @db.VarChar(20)
  cuttingType       String?  @db.VarChar(20)
  sheetsPerSheet    String?  @db.VarChar(30)
  labelGap          Decimal? @db.Decimal(4, 1)
  dieCutter         String?  @db.VarChar(20)
  resinPlate        String?  @db.VarChar(20)
  rollDirection     String?  @db.VarChar(10)
  slit              Boolean  @default(false)
  dataType          String?  @db.VarChar(20)
  lastDataDate      DateTime? @db.Date
  designFileStatus  String?  @db.VarChar(20)
  designImageUrl    String?  @db.VarChar(500)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Estimate {
  id                Int      @id @default(autoincrement())
  estimateNumber    String   @unique @db.VarChar(30)
  estimateDate      DateTime @db.Date
  clientId          Int
  clientContactName String?  @db.VarChar(50)
  stage             String   @default("1차제안") @db.VarChar(30)
  validDays         Int      @default(10)
  totalSupplyAmount Decimal  @default(0) @db.Decimal(12, 0)
  totalVat          Decimal  @default(0) @db.Decimal(12, 0)
  totalAmount       Decimal  @default(0) @db.Decimal(12, 0)
  recipientText     String?  @db.VarChar(200)
  managerId         Int?
  managerName       String?  @db.VarChar(50)
  managerTitle      String?  @db.VarChar(50)
  managerPhone      String?  @db.VarChar(30)
  managerEmail      String?  @db.VarChar(100)
  note              String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client            Client   @relation(fields: [clientId], references: [id])
  items             EstimateItem[]

  @@index([clientId])
  @@index([estimateDate])
  @@index([stage])
  @@map("estimates")
}

model EstimateItem {
  id                Int      @id @default(autoincrement())
  estimateId        Int
  productId         Int?
  productName       String   @db.VarChar(200)
  spec              String?  @db.VarChar(100)
  quantity          Int      @default(0)
  unitPrice         Decimal  @default(0) @db.Decimal(12, 0)
  supplyAmount      Decimal  @default(0) @db.Decimal(12, 0)
  vat               Decimal  @default(0) @db.Decimal(12, 0)
  quantityText      String?  @db.VarChar(50)
  unitPriceText     String?  @db.VarChar(50)
  note              String?  @db.VarChar(200)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  estimate          Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@index([estimateId])
  @@map("estimate_items")
}

model EstimateManager {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  title       String?  @db.VarChar(50)
  phone       String?  @db.VarChar(30)
  email       String?  @db.VarChar(100)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("estimate_managers")
}

model Transaction {
  id                  Int      @id @default(autoincrement())
  transactionNumber   String   @unique @db.VarChar(30)
  transactionDate     DateTime @db.Date
  clientId            Int
  bankAccountId       Int?
  totalQuantity       Int      @default(0)
  totalSupplyAmount   Decimal  @default(0) @db.Decimal(12, 0)
  totalVat            Decimal  @default(0) @db.Decimal(12, 0)
  totalAmount         Decimal  @default(0) @db.Decimal(12, 0)
  note                String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client              Client      @relation(fields: [clientId], references: [id])
  bankAccount         BankAccount? @relation(fields: [bankAccountId], references: [id])
  items               TransactionItem[]

  @@index([clientId])
  @@index([transactionDate])
  @@map("transactions")
}

model TransactionItem {
  id                Int      @id @default(autoincrement())
  transactionId     Int
  productId         Int?
  itemDate          DateTime @db.Date
  productName       String   @db.VarChar(200)
  spec              String?  @db.VarChar(100)
  quantity          Int      @default(0)
  unit              String?  @db.VarChar(20)
  unitPrice         Decimal  @default(0) @db.Decimal(12, 0)
  supplyAmount      Decimal  @default(0) @db.Decimal(12, 0)
  vat               Decimal  @default(0) @db.Decimal(12, 0)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product           Product?    @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@map("transaction_items")
}

model SalesRecord {
  id                  Int      @id @default(autoincrement())
  year                Int
  month               Int
  transactionType     String?  @db.VarChar(10)
  dataType       String?  @db.VarChar(20)
  worker              String?  @db.VarChar(50)
  deliveryType        String?  @db.VarChar(20)
  deliveryRegion      String?  @db.VarChar(50)
  orderReceivedDate   DateTime? @db.Date
  clientId            Int
  printType           String?  @db.VarChar(50)
  productName         String?  @db.VarChar(200)
  sheets              Int?
  unitPrice           Decimal? @db.Decimal(12, 0)
  supplyAmount        Decimal? @db.Decimal(12, 0)
  taxIncludedAmount   Decimal? @db.Decimal(12, 0)
  requestedDueDate    DateTime? @db.Date
  transactionDate     DateTime? @db.Date
  taxInvoiceDate      DateTime? @db.Date
  paymentDate         DateTime? @db.Date
  note                String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client              Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([year, month])
  @@index([transactionType])
  @@map("sales_records")
}

model SalesTarget {
  id                Int      @id @default(autoincrement())
  year              Int
  month             Int
  targetAmount      Decimal  @db.Decimal(12, 0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([year, month])
  @@map("sales_targets")
}

model FileUpload {
  id                Int      @id @default(autoincrement())
  fileName          String   @db.VarChar(200)
  fileUrl           String   @db.VarChar(500)
  fileSize          Int?
  mimeType          String?  @db.VarChar(50)
  entityType        String   @db.VarChar(30)
  entityId          Int
  createdAt         DateTime @default(now())

  @@index([entityType, entityId])
  @@map("file_uploads")
}
